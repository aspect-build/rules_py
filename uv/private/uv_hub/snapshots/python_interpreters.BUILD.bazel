string_flag(
    name = "python_version",
    build_setting_default = "3.13",
)

# rules_python target transitions set only their own flag. Prefer a nonempty
# rules_python value; use the generated root default only while it is empty.
config_setting(
    name = "_python_version_is_3_13_rpy",
    flag_values = {"@rules_python//python/config_settings:python_version_major_minor": "3.13"},
)

config_setting(
    name = "_python_version_is_3_13_our_fallback",
    flag_values = {
        ":python_version": "3.13",
        "@rules_python//python/config_settings:python_version_major_minor": "",
    },
)

selects.config_setting_group(
    name = "python_version_is_3_13",
    match_any = [
        ":_python_version_is_3_13_rpy",
        ":_python_version_is_3_13_our_fallback",
