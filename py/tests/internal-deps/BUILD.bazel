load("@rules_python//python:defs.bzl", "py_library")
load("//py:defs.bzl", "py_binary", "py_test", rules_py_py_library = "py_library")

rules_py_py_library(
    name = "init",
    srcs = [
        "__init__.py",
    ],
)

rules_py_py_library(
    name = "sub",
    srcs = [
        "sub.py",
    ],
    deps = [
        ":init",
    ],
)

# Forward interop: a @rules_python py_library consumed by the rules_py
# py_binary/py_test below. It can't depend on a rules_py py_library (`:init`) —
# rules_py emits its own PyInfo, not @rules_python's, which rules_python's deps
# constraint requires.
py_library(
    name = "pi",
    srcs = [
        "pi.py",
    ],
)

py_binary(
    name = "main",
    srcs = [
        "__main__.py",
    ],
    deps = [
        ":pi",
        ":sub",
        "//py/tests/internal-deps/adder",
    ],
)

py_test(
    name = "assert",
    srcs = [
        "__main__.py",
    ],
    deps = [
        ":pi",
        ":sub",
        "//py/tests/internal-deps/adder",
    ],
)
