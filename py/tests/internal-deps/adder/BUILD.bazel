runfiles paths. Keep both in the @aspect_rules_py module.
"""

load("//py:defs.bzl", "py_binary", "py_library")

py_library(
    name = "adder",
    srcs = [
        "__init__.py",
        "add.py",
    ],
    imports = [".."],
    visibility = ["//visibility:public"],
)

py_binary(
    name = "external_launcher",
    srcs = ["external_launcher.py"],
    visibility = ["//visibility:public"],
    deps = [
        ":adder",
        "@rules_python//python/runfiles",
    ],
)
