load("//py:defs.bzl", "py_test", "py_unpacked_wheel")

# Regression gate for assemble_venv's `_format_imp` fallback (see
# double_pth_test.py). Two hand-built wheels, each emitting PyWheelsInfo
# (they set `top_levels`) and each shipping a distinct root `.pth` that
# appends a unique sentinel to sys.path. Both claim the top-level
# `shared`, so the collision loser is forced through the
# `site.addsitedir` fallback — where a wheel-root `.pth` whose top-level
# was also projected into the venv would otherwise fire twice.

# A wheel is just a zip; build minimal ones with the prebuilt zipper so
# the test needs no pip / uv environment. Internal layout mirrors what
# the unpacker expects: top-level entries at the archive root plus a
# `<name>-<version>.dist-info/` directory.
genrule(
    name = "wheel_a",
    srcs = [
        "a/apkg/__init__.py",
        "a/shared/__init__.py",
        "a/a_marker.pth",
        "a/entry_points.txt",
        "a/METADATA",
    ],
    outs = ["pthtest_a-1.0-py3-none-any.whl"],
    cmd = " ".join([
        "$(execpath @bazel_tools//tools/zip:zipper) c $@",
        "apkg/__init__.py=$(execpath a/apkg/__init__.py)",
        "shared/__init__.py=$(execpath a/shared/__init__.py)",
        "a_marker.pth=$(execpath a/a_marker.pth)",
        "pthtest_a-1.0.dist-info/entry_points.txt=$(execpath a/entry_points.txt)",
        "pthtest_a-1.0.dist-info/METADATA=$(execpath a/METADATA)",
    ]),
    tools = ["@bazel_tools//tools/zip:zipper"],
)

genrule(
    name = "wheel_b",
    srcs = [
        "b/bpkg/__init__.py",
        "b/shared/__init__.py",
        "b/b_marker.pth",
        "b/METADATA",
    ],
    outs = ["pthtest_b-1.0-py3-none-any.whl"],
    cmd = " ".join([
        "$(execpath @bazel_tools//tools/zip:zipper) c $@",
        "bpkg/__init__.py=$(execpath b/bpkg/__init__.py)",
        "shared/__init__.py=$(execpath b/shared/__init__.py)",
        "b_marker.pth=$(execpath b/b_marker.pth)",
        "pthtest_b-1.0.dist-info/METADATA=$(execpath b/METADATA)",
    ]),
    tools = ["@bazel_tools//tools/zip:zipper"],
)

py_unpacked_wheel(
    name = "pthtest_a",
    src = ":pthtest_a-1.0-py3-none-any.whl",
    # `a_marker.pth` is a depth-1 RECORD entry, so a real wheel-install
    # lists it among the top-levels; declaring it here projects it into
    # the venv site-packages exactly as uv's whl_install would.
    top_levels = [
        "apkg",
        "pthtest_a-1.0.dist-info",
        "shared",
        "a_marker.pth",
    ],
)

py_unpacked_wheel(
    name = "pthtest_b",
    src = ":pthtest_b-1.0-py3-none-any.whl",
    top_levels = [
        "bpkg",
        "pthtest_b-1.0.dist-info",
        "shared",
        "b_marker.pth",
    ],
)

py_unpacked_wheel(
    name = "pthtest_unknown_layout",
    src = ":pthtest_a-1.0-py3-none-any.whl",
    # Console scripts make this target emit PyWheelsInfo, while omitting
    # top_levels requires venv assembly to preserve the complete wheel root.
    console_scripts = ["pthtest=apkg:main"],
)

py_test(
    name = "double_pth_test",
    srcs = ["double_pth_test.py"],
    # site.py only processes `.pth` files (the side effect under test)
    # when the venv's site-packages is treated as a site dir, which the
    # isolated launcher suppresses.
    isolated = False,
    main = "double_pth_test.py",
    # The two wheels collide on `shared`; downgrade so the build doesn't
    # fail before the venv is assembled.
    package_collisions = "warning",
    deps = [
        ":pthtest_a",
        ":pthtest_b",
    ],
)

py_test(
    name = "unknown_layout_pth_test",
    srcs = ["unknown_layout_pth_test.py"],
    isolated = False,
    main = "unknown_layout_pth_test.py",
    deps = [":pthtest_unknown_layout"],
)
