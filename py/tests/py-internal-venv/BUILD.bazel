load("//py:defs.bzl", "py_test")

# Two variants of the same test: `test` uses `py_test` with the
# default internal (private-sibling) venv shape; `venv_test` uses
# `py_test(expose_venv = True, isolated = False)` — the opt-in
# public-sibling shape. Both should satisfy the structural
# assertions in test.py (they're basename-tolerant).

py_test(
    name = "test",
    srcs = [
        "test.py",
    ],
    imports = [
        ".",
    ],
    main = "test.py",
    deps = [
        "@pypi//cowsay",
    ],
)

py_test(
    name = "venv_test",
    srcs = [
        "test.py",
    ],
    expose_venv = True,
    imports = [
        ".",
    ],
    isolated = False,
    main = "test.py",
    deps = [
        "@pypi//cowsay",
    ],
)
