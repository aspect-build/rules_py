load("//py:defs.bzl", "py_test")

# Two variants of the same test: `test` uses `py_test` defaults
# (`isolated = True`); `test_non_isolated` flips `isolated = False`.
# Both should satisfy the structural assertions in test.py (they're
# basename-tolerant).

py_test(
    name = "test",
    srcs = [
        "test.py",
    ],
    imports = [
        ".",
    ],
    main = "test.py",
    deps = [
        "@pypi//cowsay",
    ],
)

py_test(
    name = "test_non_isolated",
    srcs = [
        "test.py",
    ],
    imports = [
        ".",
    ],
    isolated = False,
    main = "test.py",
    deps = [
        "@pypi//cowsay",
    ],
)
