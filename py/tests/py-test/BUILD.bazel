load("//py:defs.bzl", "py_test")

py_test(
    name = "test_env_vars",
    srcs = ["test_env_vars.py"],
    data = [
        "test_env_vars.py",
    ],
    env = {
        "ONE": "un",
        "TWO": "deux",
        "RULEDIR": "$(RULEDIR)",
        "LOCATION": "$(location :test_env_vars.py)",
        "DEFINE": "$(SOME_VAR)",
    },
)

# `expose_venv = True` counterpart of the VIRTUAL_ENV assertion in
# :test_env_vars — exercises the public-venv path, where the venv's own
# RunEnvironmentInfo also feeds the merged runtime env.
py_test(
    name = "test_virtual_env_exposed",
    srcs = ["test_virtual_env_exposed.py"],
    expose_venv = True,
)
