load("@bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("//py/private/py_venv:py_venv.bzl", "py_venv")
load("//py/private/py_venv:py_venv_exec.bzl", "py_venv_exec")

# Snapshots of the launcher scripts generated by the two `expand_template`
# call sites in //py/private/py_venv:
#
#   - run.tmpl.sh  -> `py_venv_exec`'s executable launcher
#   - venv.tmpl.sh -> `py_venv`'s executable launcher
#
# The fixture targets are not run; they exist purely so the substituted
# template outputs land in bazel-bin where a genrule can copy them into
# the data-only snapshots/ subdirectory. A regression in the template
# body, the rule's substitution dict, or the runfiles-path conventions
# will surface as a diff against the pinned files in snapshots/.
#
# To update after an intentional change, run:
#   bazel run //py/tests:snapshots

py_venv(
    name = "snapshot_venv",
    srcs = ["main.py"],
)

py_venv_exec(
    name = "snapshot_exec",
    srcs = ["main.py"],
    main = "main.py",
    venv = ":snapshot_venv",
)

# `tools = [...]` resolves $(execpath) to the single executable
# launcher rather than the multi-file DefaultInfo set.
genrule(
    name = "extract_run_launcher",
    outs = ["run.launcher.snap.sh"],
    cmd = "cp $(execpath :snapshot_exec) $@",
    tools = [":snapshot_exec"],
)

genrule(
    name = "extract_venv_launcher",
    outs = ["venv.launcher.snap.sh"],
    cmd = "cp $(execpath :snapshot_venv) $@",
    tools = [":snapshot_venv"],
)

write_source_files(
    name = "snapshots",
    files = {
        "snapshots/run.launcher.sh": ":extract_run_launcher",
        "snapshots/venv.launcher.sh": ":extract_venv_launcher",
    },
)
