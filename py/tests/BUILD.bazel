load("@bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("//py/private/py_venv:defs.bzl", "py_venv", "py_venv_exec")

# Snapshot of the launcher script generated by `expand_template` in
# //py/private/py_venv:py_venv.bzl — the `.venv` interactive launcher
# (venv.tmpl.sh). The `py_venv_exec` launcher is now a native binary
# from hermetic_launcher, so a byte snapshot isn't meaningful there;
# behavior for that path is covered by the functional tests under
# py/tests/*.
#
# The fixture target is not run; it exists so the substituted template
# output lands in bazel-bin where the genrule can copy it into the
# data-only snapshots/ subdirectory. A regression in the template body,
# the rule's substitution dict, or the runfiles-path conventions will
# surface as a diff against the pinned file in snapshots/.
#
# To update after an intentional change, run:
#   bazel run //py/tests:snapshots

py_venv(
    name = "snapshot_venv",
    srcs = ["main.py"],
)

py_venv_exec(
    name = "snapshot_exec",
    srcs = ["main.py"],
    main = "main.py",
    venv = ":snapshot_venv",
)

# `tools = [...]` resolves $(execpath) to the single executable
# launcher rather than the multi-file DefaultInfo set.
genrule(
    name = "extract_venv_launcher",
    outs = ["venv.launcher.snap.sh"],
    cmd = "cp $(execpath :snapshot_venv) $@",
    tools = [":snapshot_venv"],
)

write_source_files(
    name = "snapshots",
    files = {
        "snapshots/venv.launcher.sh": ":extract_venv_launcher",
    },
)
