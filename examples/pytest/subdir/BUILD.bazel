load("@aspect_rules_py//py:defs.bzl", "py_library", "py_pytest_test", "py_test")

py_library(
    name = "foo",
    srcs = ["foo.py"],
    imports = ["."],
)

py_test(
    name = "test_without_pytest_main",
    srcs = ["tests/test_subdir.py"],
    deps = [":foo"],
)

py_pytest_test(
    name = "test_with_pytest_main",
    srcs = ["tests/test_subdir.py"],
    deps = [
        ":foo",
        "@pypi//pytest",
    ],
)
