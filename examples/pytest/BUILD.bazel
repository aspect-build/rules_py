# Regression test for py_pytest_main(chdir = "..."): the chdir
# template substitution in py_pytest_main.bzl must land an os.chdir()
# call into the generated pytest main, so the test starts with its CWD
# pointing at the requested directory. chdir_test.py then verifies
# that a relative open("hello.json") resolves without needing an
# absolute runfiles path.
# After chdir into examples/pytest/fixtures/, pytest can't auto-discover
# the test file (chdir_test.py lives one level up). Pass a path that
# resolves from the post-chdir cwd so pytest collects the intended test.
py_pytest_main(
    name = "chdir_main",
    args = ["../chdir_test.py"],
    chdir = "examples/pytest/fixtures",
)

py_test(
    name = "chdir_test",
    srcs = [
        "chdir_test.py",
        ":chdir_main",
    ],
    data = glob(["fixtures/*.json"]),
    main = ":__test__chdir_main__.py",
    deps = [
        ":chdir_main",
        "@pypi//pytest",
    ],
)

# Regression test for #723: test targets named test_* must work with
