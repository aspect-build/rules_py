load("@aspect_rules_py//py:defs.bzl", "py_test")

# Regression: pyahocorasick 2.2.0 builds a real C extension from an
# sdist that contains setup.py + setup.cfg but no pyproject.toml.
# `no-binary-package = ["pyahocorasick"]` in the parent pyproject.toml
# forces the resolver to build from sdist, routing the wheel build
# through pep517_native_whl/build_helper.py.
#
# Once a native sdist build is in play, every path-shaped thing
# `build_helper.py` exports to its compiler subprocess must survive
# the cwd change into the worktree. Two cooperating fixes from the
# zbarsky-openai patch chain make this work:
#
# 1. `tmp_root = path.abspath(opts.outdir) + ".tmp"` (from
#    `f12313870`). Was relative — `bazel-out/.../whl.tmp` — and
#    invalid from any cwd other than the action's execroot.
# 2. CC/CXX wrappers under `tmp_root/.aspect_rules_py_compilers/`
#    (from `5d81044`), pointed to by `CC` / `CXX` / `CPP` /
#    `LDSHARED` / `LDCXXSHARED` so the Bazel-relative
#    `$(CC)`-expansion (e.g. `external/llvm+/toolchain/gcc`) gets
#    replaced with an absolute wrapper path before setup.py invokes
#    the compiler from inside the worktree.
#
# Constrained to linux for the same reason as uv-sdist-native-build:
# the host-side cc toolchain plumbing that lets a `setup.py
# bdist_wheel` actually compile a C extension is only wired up there
# in this e2e setup.
py_test(
    name = "test",
    srcs = ["__test__.py"],
    dep_group = "uv_pyproject_cases",
    main = "__test__.py",
    python_version = "3.11",
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "@pypi_uv_pyproject_cases//pyahocorasick",
    ],
)
