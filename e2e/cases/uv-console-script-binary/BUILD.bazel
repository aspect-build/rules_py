load("@aspect_rules_py//uv/unstable:defs.bzl", "py_console_script_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

py_console_script_binary(
    name = "whoowns",
    pkg = "@pypi//whoowns",
    venv = "uv-console-script-binary",
)

py_console_script_binary(
    name = "whoowns_explicit",
    pkg = "@pypi//whoowns",
    script = "whoowns",
    venv = "uv-console-script-binary",
)

py_console_script_binary(
    name = "mkdocs",
    pkg = "@pypi//mkdocs",
    script = "mkdocs",
    venv = "uv-console-script-binary",
    deps = [
        "@pypi//mkdocs_github_admonitions_plugin",
    ],
)

sh_test(
    name = "test",
    srcs = ["test.sh"],
    data = [
        "docs/index.md",
        "mkdocs.yml",
        ":mkdocs",
        ":whoowns",
        ":whoowns_explicit",
    ],
)
