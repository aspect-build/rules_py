load("@aspect_rules_py//py:defs.bzl", "py_test")

# Regression: different lockfile wheel entries can map to the same fetched
# http_file label. whl_install must receive a deduplicated label_list while
# still preserving metadata for each selectable wheel basename.
py_test(
    name = "test_import",
    srcs = ["test_import.py"],
    dep_group = "duplicate-whl-labels",
    main = "test_import.py",
    deps = ["@pypi_uv_duplicate_whl_labels//six"],
)
