"""Each OCI sub-case has its own pyproject + lock (colorama dep). They live
in dedicated hubs alongside the other cases.
"""

uv = use_extension("@aspect_rules_py//uv:extensions.bzl", "uv")
uv.declare_hub(hub_name = "pypi_oci_py_image_layer")
uv.project(
    hub_name = "pypi_oci_py_image_layer",
    lock = "//oci/py_image_layer:uv.lock",
    pyproject = "//oci/py_image_layer:pyproject.toml",
)
use_repo(uv, "pypi_oci_py_image_layer")

uv.declare_hub(hub_name = "pypi_oci_py_venv_image_layer")
uv.project(
    hub_name = "pypi_oci_py_venv_image_layer",
    lock = "//oci/py_venv_image_layer:uv.lock",
    pyproject = "//oci/py_venv_image_layer:pyproject.toml",
)
use_repo(uv, "pypi_oci_py_venv_image_layer")
