_CC_TOOLCHAIN = "//pep517-frontend-exec-group:cc_toolchain"

_CONFIGURED_CC_TOOLCHAIN = "//pep517-frontend-exec-group:configured_cc_toolchain"

_MINIMAL_CXX_TOOLCHAIN = "//pep517-frontend-exec-group:minimal_cxx_toolchain"

_WRAPPED_CXX_TOOLCHAIN = "//pep517-frontend-exec-group:wrapped_cxx_toolchain"

_LEGACY_CC_TOOLCHAIN = "//pep517-frontend-exec-group:legacy_cc_toolchain"

# Keep the host first so the default exec group selects it. The native wheel's
# `target` exec group requires the transitioned target constraints and selects
# the second platform instead. Platform flags are applied in the configuration
# that selects the platform:
# https://bazel.build/reference/be/platforms-and-toolchains#platform
platform(
    name = "linux_aarch64",
    constraint_values = [
        "@platforms//cpu:aarch64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_aarch64",
        "--extra_toolchains=" + _CC_TOOLCHAIN,
    ],
)

platform(
    name = "linux_x86_64",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_x86_64",
        "--extra_toolchains=" + _CC_TOOLCHAIN,
    ],
)

platform(
    name = "linux_configured",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_configured",
        "--extra_toolchains=" + _CONFIGURED_CC_TOOLCHAIN,
    ],
)

platform(
    name = "linux_legacy",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_legacy",
        "--extra_toolchains=" + _LEGACY_CC_TOOLCHAIN,
    ],
)

platform(
    name = "linux_minimal_cxx",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_minimal_cxx",
        "--extra_toolchains=" + _MINIMAL_CXX_TOOLCHAIN,
    ],
)

platform(
    name = "linux_wrapped_cxx",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = [
        "--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc",
        "--extra_execution_platforms=@platforms//host,//pep517-frontend-exec-group:linux_wrapped_cxx",
        "--extra_toolchains=" + _WRAPPED_CXX_TOOLCHAIN,
    ],
)

config_setting(
    name = "linux_aarch64_config",
    constraint_values = [
        "@platforms//cpu:aarch64",
        "@platforms//os:linux",
    ],
)

config_setting(
    name = "linux_x86_64_config",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
)

write_file(
    name = "linux_aarch64_compiler",
    out = "linux_aarch64_compiler.sh",
    content = [
        "#!/usr/bin/env bash",
        "printf '%s\\n' aarch64",
    ],
    is_executable = True,
)

write_file(
    name = "linux_x86_64_compiler",
    out = "linux_x86_64_compiler.sh",
    content = [
        "#!/usr/bin/env bash",
        "printf '%s\\n' x86_64",
    ],
    is_executable = True,
)

fake_cc_toolchain(
    name = "cc",
    compiler = select({
        ":linux_aarch64_config": ":linux_aarch64_compiler",
        ":linux_x86_64_config": ":linux_x86_64_compiler",
        "//conditions:default": ":linux_x86_64_compiler",
    }),
)

# The toolchain target is configured for its execution platform. Resolving it
# in the default group therefore exposes the host compiler, while resolving it
# in the native wheel's target group exposes the transitioned target compiler.
toolchain(
    name = "cc_toolchain",
    toolchain = ":cc",
    toolchain_type = "@bazel_tools//tools/cpp:toolchain_type",
)

write_file(
    name = "unusual_c_driver",
    out = "unusual_c_driver.sh",
    content = [
        "#!/usr/bin/env bash",
        "printf '%s\\n' c-action",
    ],
    is_executable = True,
)

write_file(
    name = "unusual_cxx_driver",
    out = "unusual_cxx_driver.sh",
    content = [
        "#!/usr/bin/env bash",
        "printf '%s\\n' cxx-action",
    ],
    is_executable = True,
)

cc_tool(
    name = "configured_c_tool",
    src = ":unusual_c_driver",
)

cc_tool(
    name = "configured_cxx_tool",
    src = ":unusual_cxx_driver",
)

cc_tool_map(
    name = "configured_tool_map",
    tools = {
        "@rules_cc//cc/toolchains/actions:c_compile": ":configured_c_tool",
        "@rules_cc//cc/toolchains/actions:cpp_compile_actions": ":configured_cxx_tool",
        "@rules_cc//cc/toolchains/actions:link_actions": ":configured_c_tool",
        "@rules_cc//cc/toolchains/actions:strip": ":configured_c_tool",
        "@rules_cc//cc/toolchains/actions:ar_actions": ":configured_c_tool",
    },
)

cc_toolchain(
    name = "configured_cc",
    tool_map = ":configured_tool_map",
)

toolchain(
    name = "configured_cc_toolchain",
    toolchain = ":configured_cc",
    toolchain_type = "@bazel_tools//tools/cpp:toolchain_type",
)

write_file(
    name = "minimal_c_driver",
    out = "clang-22",
    content = [
        "#!/usr/bin/env bash",
        "exec /usr/bin/cc \"$@\"",
    ],
    is_executable = True,
)

write_file(
    name = "minimal_cxx_driver",
    out = "clang++-22",
    content = [
        "#!/usr/bin/env bash",
        "exec /usr/bin/c++ \"$@\"",
    ],
    is_executable = True,
)

fake_cc_toolchain(
    name = "minimal_cxx",
    compiler = ":minimal_c_driver",
    tools = [":minimal_cxx_driver"],
)

toolchain(
    name = "minimal_cxx_toolchain",
    toolchain = ":minimal_cxx",
    toolchain_type = "@bazel_tools//tools/cpp:toolchain_type",
)

write_file(
    name = "wrapped_c_driver",
    out = "payload/clang",
    content = [
        "#!/usr/bin/env bash",
        "exec /usr/bin/cc \"$@\"",
    ],
    is_executable = True,
)

write_file(
    name = "wrapped_cxx_driver",
    out = "payload/clang++",
    content = [
        "#!/usr/bin/env bash",
        "echo 'raw clang++ payload must not bypass cc_wrapper.sh' >&2",
        "exit 97",
    ],
    is_executable = True,
)

write_file(
    name = "cc_wrapper",
    out = "cc_wrapper.sh",
    content = [
        "#!/usr/bin/env bash",
        "for arg in \"$@\"; do if [[ \"${arg}\" == -c || \"${arg}\" == -E || \"${arg}\" == -S || \"${arg}\" == -M || \"${arg}\" == -MM || \"${arg}\" == -fsyntax-only ]]; then exec \"$(dirname \"$0\")/payload/clang\" -DRULES_PY_WRAPPER_CONFIG=1 \"$@\"; fi; done",
        "echo 'compile wrapper must not perform C++ links' >&2",
        "exit 98",
    ],
    is_executable = True,
)

write_file(
    name = "wrapped_shared_driver",
    out = "shared_wrapper.sh",
    content = [
        "#!/usr/bin/env bash",
        "for arg in \"$@\"; do if [[ \"${arg}\" == -shared || \"${arg}\" == -dynamiclib || \"${arg}\" == -bundle ]]; then exec /usr/bin/c++ \"$@\"; fi; done",
        "echo 'shared wrapper received a non-shared link' >&2",
        "exit 96",
    ],
    is_executable = True,
)

write_file(
    name = "wrapped_exe_driver",
    out = "exe_wrapper.sh",
    content = [
        "#!/usr/bin/env bash",
        "for arg in \"$@\"; do if [[ \"${arg}\" == -shared || \"${arg}\" == -dynamiclib || \"${arg}\" == -bundle ]]; then echo 'executable wrapper received a shared link' >&2; exit 95; fi; done",
        "exec /usr/bin/c++ \"$@\"",
    ],
    is_executable = True,
)

cc_tool(
    name = "wrapped_c_tool",
    src = ":cc_wrapper",
    data = [
        ":wrapped_c_driver",
        ":wrapped_cxx_driver",
    ],
)

cc_tool(
    name = "wrapped_shared_tool",
    src = ":wrapped_shared_driver",
)

cc_tool(
    name = "wrapped_exe_tool",
    src = ":wrapped_exe_driver",
)

cc_tool_map(
    name = "wrapped_tool_map",
    tools = {
        "@rules_cc//cc/toolchains/actions:c_compile": ":wrapped_c_tool",
        "@rules_cc//cc/toolchains/actions:cpp_compile": ":wrapped_c_tool",
        "@rules_cc//cc/toolchains/actions:cpp_link_dynamic_library": ":wrapped_shared_tool",
        "@rules_cc//cc/toolchains/actions:cpp_link_executable": ":wrapped_exe_tool",
        "@rules_cc//cc/toolchains/actions:strip": ":wrapped_c_tool",
        "@rules_cc//cc/toolchains/actions:ar_actions": ":wrapped_c_tool",
    },
)

cc_toolchain(
    name = "wrapped_cxx",
    args = [
        ":wrapped_compile_args",
        ":wrapped_link_args",
    ],
    tool_map = ":wrapped_tool_map",
)

cc_args(
    name = "wrapped_compile_args",
    actions = ["@rules_cc//cc/toolchains/actions:cpp_compile"],
    args = [
        "-DRULES_PY_WRAPPER_CONFIG=1",
        "-DRULES_PY_FEATURE_CONFIG=1",
        "--sysroot=toolchain/sysroot",
        "--gcc-toolchain=toolchain/gcc",
        "-resource-dir=toolchain/resource",
        "-isystem",
        "third_party/include",
        "-Xclang",
        "-internal-isystem",
        "-Xclang",
        "third_party/include-internal",
    ],
)

cc_args(
    name = "wrapped_link_args",
    actions = [
        "@rules_cc//cc/toolchains/actions:cpp_link_dynamic_library",
        "@rules_cc//cc/toolchains/actions:cpp_link_executable",
    ],
    args = [
        "-Wl,-rpath,/aspect_rules_py_toolchain",
    ],
)

toolchain(
