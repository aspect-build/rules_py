write_file(
    name = "frontend_script",
    out = "frontend.sh",
    content = [
        "#!/usr/bin/env bash",
        "set -euo pipefail",
    ] + select({
        ":linux_aarch64_config": ["actual=aarch64"],
        ":linux_x86_64_config": ["actual=x86_64"],
        "//conditions:default": ["actual=default"],
    }) + [
        "expected=\"$1\"",
        "if [[ \"${actual}\" != \"${expected}\" ]]; then",
        "  echo \"frontend used ${actual}; expected ${expected}\" >&2",
        "  exit 1",
        "fi",
        "compiler_actual=\"$(\"${CC}\")\"",
        "if [[ \"${compiler_actual}\" != \"${expected}\" ]]; then",
        "  echo \"compiler ${CC} reported ${compiler_actual}; expected ${expected}\" >&2",
        "  exit 1",
        "fi",
        "wheel_dir=\"${!#}\"",
        "mkdir -p \"${wheel_dir}\"",
    ],
    is_executable = True,
)

sh_binary(
    name = "frontend",
    srcs = [":frontend_script"],
)

write_file(
    name = "configured_frontend_script",
    out = "configured_frontend.sh",
    content = [
        "#!/usr/bin/env bash",
        "set -euo pipefail",
        "c_actual=\"$(\"${CC}\")\"",
        "cxx_actual=\"$(\"${CXX}\")\"",
        "if [[ \"${c_actual}\" != c-action || \"${cxx_actual}\" != cxx-action ]]; then",
        "  echo \"configured tools reported ${c_actual} and ${cxx_actual}\" >&2",
        "  exit 1",
        "fi",
        "wheel_dir=\"${!#}\"",
        "mkdir -p \"${wheel_dir}\"",
    ],
    is_executable = True,
)

sh_binary(
    name = "configured_frontend",
    srcs = [":configured_frontend_script"],
)

write_file(
    name = "cxx_frontend_script",
    out = "cxx_frontend.sh",
    content = [
        "#!/usr/bin/env bash",
        "set -eo pipefail",
        "expected_cc=\"$1\"",
        "expected_cxx=\"$2\"",
        "expected_config=\"$3\"",
        "export expected_config",
        "if [[ \"${CC-unset}\" != ${expected_cc} || \"${CXX-unset}\" != ${expected_cxx} ]]; then",
        "  echo \"C++ tools were not selected: CC=${CC-unset} CXX=${CXX-unset}\" >&2",
        "  exit 1",
        "fi",
        "wheel_dir=\"${!#}\"",
        "mkdir -p \"${wheel_dir}\"",
        "compile_flags=()",
        "while IFS= read -r flag; do [[ -z \"${flag}\" ]] || compile_flags+=(\"${flag}\"); done < <(/usr/bin/python3 -c 'import json, os; config = json.loads(os.environ.get(\"ASPECT_RULES_PY_CXX_TOOLCHAIN_CONFIG\", \"{}\")); flags = config.get(\"cxx_compile_flags\", []); marker = \"__ASPECT_RULES_PY_EXECROOT__/\"; expected = [\"--sysroot=\" + marker + \"toolchain/sysroot\", \"--gcc-toolchain=\" + marker + \"toolchain/gcc\", \"-resource-dir=\" + marker + \"toolchain/resource\", marker + \"third_party/include\", marker + \"third_party/include-internal\"]; assert os.environ[\"expected_config\"] == \"0\" or all(flag in flags for flag in expected), flags; print(*[flag for flag in flags if flag.startswith(\"-D\")], sep=\"\\n\")')",
        "link_flags=()",
        "while IFS= read -r flag; do [[ -z \"${flag}\" ]] || link_flags+=(\"${flag}\"); done < <(/usr/bin/python3 -c 'import json, os; config = json.loads(os.environ.get(\"ASPECT_RULES_PY_CXX_TOOLCHAIN_CONFIG\", \"{}\")); print(*config.get(\"cxx_exe_link_flags\", []), sep=\"\\n\")')",
        "printf '%s\\n' '#include <string>' '#ifndef RULES_PY_WRAPPER_CONFIG' '#define RULES_PY_WRAPPER_CONFIG 0' '#endif' '#ifndef RULES_PY_FEATURE_CONFIG' '#define RULES_PY_FEATURE_CONFIG 0' '#endif' '#if RULES_PY_WRAPPER_CONFIG != RULES_PY_EXPECT_CONFIG || RULES_PY_FEATURE_CONFIG != RULES_PY_EXPECT_CONFIG' '#error toolchain configuration was not preserved' '#endif' 'struct Base { virtual ~Base() {} };' 'struct Value : Base { std::string value; Value() : value(\"rules_py\") {} };' 'int main() { Value value; Base *base = &value; Value *result = dynamic_cast<Value *>(base); return result && result->value == \"rules_py\" ? 0 : 1; }' > \"${wheel_dir}/probe.cc\"",
        "\"${CXX}\" \"${compile_flags[@]}\" -DRULES_PY_EXPECT_CONFIG=\"${expected_config}\" -std=c++11 -c \"${wheel_dir}/probe.cc\" -o \"${wheel_dir}/probe.o\"",
        "link_tool=\"$(/usr/bin/python3 -c 'import json, os; config = json.loads(os.environ.get(\"ASPECT_RULES_PY_CXX_TOOLCHAIN_CONFIG\", \"{}\")); print(config.get(\"cxx_exe_link_tool\", os.environ[\"CXX\"]))')\"",
        "\"${link_tool}\" \"${wheel_dir}/probe.o\" -o \"${wheel_dir}/probe\" \"${link_flags[@]}\"",
        "\"${wheel_dir}/probe\"",
    ],
    is_executable = True,
)

sh_binary(
    name = "cxx_frontend",
    srcs = [":cxx_frontend_script"],
)

write_file(
    name = "legacy_frontend_script",
    out = "legacy_frontend.sh",
    content = [
        "#!/usr/bin/env bash",
        "set -euo pipefail",
        "execroot=\"${PWD}\"",
        "if [[ \"${AR-unset}\" != */legacy_archiver.sh || \"${CC-unset}\" != */legacy_compiler.sh || \"${CXX-unset}\" != */legacy_compiler.sh || \"${LD-unset}\" != */legacy_compiler.sh || \"${STRIP-unset}\" != */legacy_compiler.sh ]]; then",
        "  echo \"legacy tools were not selected: AR=${AR-unset} CC=${CC-unset} CXX=${CXX-unset} LD=${LD-unset} STRIP=${STRIP-unset}\" >&2",
        "  exit 1",
        "fi",
        "wheel_dir=\"${!#}\"",
        "wheel_dir=\"${execroot}/${wheel_dir}\"",
        "work_dir=\"${wheel_dir}.tmp\"",
        "/bin/mkdir -p \"${wheel_dir}\" \"${work_dir}/poison\"",
        "for tool in cc c++ ar ld strip; do",
        "  printf '%s\\n' '#!/bin/sh' 'echo ambient tool selected >&2' 'exit 97' > \"${work_dir}/poison/${tool}\"",
        "  /bin/chmod +x \"${work_dir}/poison/${tool}\"",
        "done",
        "export PATH=\"${work_dir}/poison:/usr/bin:/bin\"",
        "cd \"${work_dir}\"",
        "printf '%s\\n' 'int c_value(void) { return 42; }' > dep.c",
        "printf '%s\\n' 'extern \"C\" int c_value(void);' 'int main() { return c_value() == 42 ? 0 : 1; }' > main.cc",
        "\"${execroot}/${CC}\" -c dep.c -o dep.o",
        "\"${execroot}/${AR}\" rcs libdep.a dep.o",
        "\"${execroot}/${CXX}\" -c main.cc -o main.o",
        "\"${execroot}/${CXX}\" main.o libdep.a -o native",
        "./native",
    ],
    is_executable = True,
)

sh_binary(
    name = "legacy_frontend",
    srcs = [":legacy_frontend_script"],
)

