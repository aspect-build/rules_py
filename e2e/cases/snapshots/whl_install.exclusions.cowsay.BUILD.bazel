    namespace_top_levels = {},
    console_scripts = {
        "cowsay-6.0-py2.py3-none-any.whl": [
            "cowsay=cowsay.__main__:cli",
        ],
    },
    top_level_dirs = {
        "cowsay-6.0-py2.py3-none-any.whl": [
            "cowsay",
        ],
    },
    patches = ["@@//uv-exclusions/patches:nested_test.patch"],
