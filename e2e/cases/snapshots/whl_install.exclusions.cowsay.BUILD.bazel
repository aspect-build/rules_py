   arms = {
       "@aspect_rules_py_pip_configurations//:py3-any-none": "@whl__cowsay__77b07c508af48aa3//file",
       "@aspect_rules_py_pip_configurations//:py2-any-none": "@whl__cowsay__77b07c508af48aa3//file",
   },
