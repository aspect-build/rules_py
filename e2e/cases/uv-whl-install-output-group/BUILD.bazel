# Regression test: whl_install must expose install_dir via OutputGroupInfo.
#
# Since #907 removed install_dir from DefaultInfo.files, consumers that need
# to extract files from a wheel directory must use a filegroup with
# output_group = "install_dir". This analysis test verifies that OutputGroupInfo
# is present on whl_install and contains exactly one TreeArtifact named "install".

load(":tests.bzl", "whl_install_output_group_test_suite")

whl_install_output_group_test_suite()
