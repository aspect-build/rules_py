"""Regression for usable wheels that contain incompatible Python sources."""

uv = use_extension("@aspect_rules_py//uv:extensions.bzl", "uv")
uv.declare_hub(hub_name = "pypi_uv_incompatible_wheel_source")
uv.project(
    hub_name = "pypi_uv_incompatible_wheel_source",
    lock = "//uv-incompatible-wheel-source:uv.lock",
    pyproject = "//uv-incompatible-wheel-source:pyproject.toml",
)
use_repo(uv, "pypi_uv_incompatible_wheel_source")
