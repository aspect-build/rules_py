# Forces hub analysis + wheel fetch + venv assembly for all direct deps
# (and their transitive closure). The test body itself is trivial
# (`import sys`), so the measured wall time isolates Bazel + uv cost
# from Python import cost.
py_test(
    name = "venv_build",
    srcs = ["//:venv_build_test.py"],
    dep_group = "perf_top500",
