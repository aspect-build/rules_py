    name = "rules_python_target_31213",
    srcs = ["rules_python_version_test.py"],
    env = select({
        ":python_at_least_313": {
            "EXPECTED_PYTHON_VERSION": "3.12.13",
            "UV_CONSTRAINT_AT_LEAST_313": "yes",
        },
        "//conditions:default": {
            "EXPECTED_PYTHON_VERSION": "3.12.13",
            "UV_CONSTRAINT_AT_LEAST_313": "no",
        },
    }),
    main = "rules_python_version_test.py",
    python_version = "3.12.13",
)

