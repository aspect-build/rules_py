load("@aspect_rules_py//uv/private/constraints/python:defs.bzl", "is_python_version_at_least")
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_python//python:defs.bzl", rules_python_py_binary = "py_binary")
load(":toolchain_test.bzl", "cross_platform_interpreter_check", "interpreter_toolchain_check", "version_transition_check", "windows_repository_check")

package(default_visibility = ["//visibility:public"])

constraint_setting(name = "target_compatibility")

constraint_value(
    name = "target_compatible",
    constraint_setting = ":target_compatibility",
)

constraint_setting(name = "exec_compatibility")

constraint_value(
    name = "exec_compatible",
    constraint_setting = ":exec_compatibility",
)

platform(
    name = "target_only_platform",
    constraint_values = [":target_compatible"],
    parents = ["@platforms//host"],
)

platform(
    name = "exec_only_platform",
    constraint_values = [":exec_compatible"],
    parents = ["@platforms//host"],
)

platform(
    name = "linux_x86_64_gnu_target_platform",
    constraint_values = [
        ":target_compatible",
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = ["--@aspect_rules_py//uv/private/constraints/platform:platform_libc=glibc"],
)

platform(
    name = "linux_x86_64_musl_target_platform",
    constraint_values = [
        ":target_compatible",
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
    flags = ["--@aspect_rules_py//uv/private/constraints/platform:platform_libc=musl"],
)

platform(
    # This name records the support boundary; Bazel has no executor-libc
    # constraint corresponding to the target-only platform_libc flag.
    name = "linux_x86_64_glibc_exec_platform",
    constraint_values = [
        ":exec_compatible",
        "@platforms//cpu:x86_64",
        "@platforms//os:linux",
    ],
)

platform(
    name = "macos_aarch64_exec_platform",
    constraint_values = [
        ":exec_compatible",
        "@platforms//cpu:aarch64",
        "@platforms//os:macos",
    ],
)

platform(
    name = "windows_x86_64_target_platform",
    constraint_values = [
        "@platforms//cpu:x86_64",
        "@platforms//os:windows",
    ],
)

config_setting(
    name = "config_311",
    define_values = {"interpreter_setting": "311"},
)

config_setting(
    name = "config_311_secondary",
    define_values = {"interpreter_setting_secondary": "311"},
)

config_setting(
    name = "config_314",
    define_values = {"interpreter_setting": "314"},
)

config_setting(
    name = "config_315",
    define_values = {"interpreter_setting": "315"},
)

cc_binary(
    name = "python_h_smoke",
    srcs = ["python_h_smoke.cc"],
    deps = [
        "@rules_python//python/cc:current_py_cc_headers",
        "@rules_python//python/cc:current_py_cc_libs",
    ],
)

