module(name = "all_lock_override_ambiguous_version")

bazel_dep(name = "aspect_rules_py")
local_path_override(
    module_name = "aspect_rules_py",
    path = "../../../..",
)

uv = use_extension("@aspect_rules_py//uv:extensions.bzl", "uv")
uv.declare_hub(hub_name = "ambiguous_hub")
uv.project(
    hub_name = "ambiguous_hub",
    lock = "//:uv.lock",
    pyproject = "//:pyproject.toml",
)
uv.override_package(
    name = "demo",
    extra_data = ["//:pyproject.toml"],
)
use_repo(uv, "ambiguous_hub")
