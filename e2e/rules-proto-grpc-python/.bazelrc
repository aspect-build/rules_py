# Inherit the repo-wide flag preset. This module's workspace root is
# e2e/rules-proto-grpc-python/, so %workspace% climbs two directories up to the
# repo root where bazelrc-preset.bzl generates bazel/defaults.bazelrc.
import %workspace%/../../bazel/defaults.bazelrc

# Build without the bytes on CI.
common:ci --remote_download_outputs=minimal
common:ci --nobuild_runfile_links

# This module does not commit a MODULE.bazel.lock — see the repo-root
# .gitignore. Overrides the preset's `common:ci --lockfile_mode=error`, so it
# must come after the import above.
common:ci --lockfile_mode=off

# protobuf's prebuilt-protoc toolchain (@protobuf//bazel/private/oss/toolchains/
# prebuilt) calls ctx.actions.run_shell without a `toolchain` parameter, which
# fails analysis under the preset's --incompatible_auto_exec_groups. The other
# workspaces avoid this only by not inheriting the preset; disable the flag here
# so the preset can still be shared. Remove once protobuf sets the parameter.
common --incompatible_auto_exec_groups=false
