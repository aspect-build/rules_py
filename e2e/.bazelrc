common --incompatible_enable_cc_toolchain_resolution
common --@llvm//config:experimental_stub_libgcc_s
common --@rules_cc//cc/toolchains/args/archiver_flags:use_libtool_on_macos=false

# Don't try and auto detect the cc toolchain, as we use our own llvm toolchains.
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1

# rules_rs experimental toolchains require an llvm libc constraint on the target platform.
# The auto-detected host platform on Linux doesn't have one, so set it explicitly.
# @llvm//platforms:linux_amd64 has @llvm//constraints/libc:gnu.2.28 by default.
common --enable_platform_specific_config
common:linux --platforms=@llvm//platforms:linux_amd64
common:linux --host_platform=@llvm//platforms:linux_amd64

# Configure a default venv
# common --@pypi//venv=say

# Enable path mapping so WhlInstall actions are exercised with
# supports-path-mapping. Actions that declare the execution requirement get
# configuration-stripped cache keys; those that don't still work normally.
build --experimental_output_paths=strip
